{
    "name": "appleple/acms-ai",
    "description": "ChatGPTを利用し、タイトルとタグが生成できる拡張アプリです。",
    "autoload": {
        "psr-4": {
            "Acms\\Plugins\\AI\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acms\\Plugins\\AI\\Tests\\": "tests/phpunit/"
        }
    },
    "scripts": {
        "post-install-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
        "post-update-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/phpcs --standard=phpcs.xml.dist",
        "format": "vendor/bin/phpcbf --standard=phpcs.xml.dist",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ],
        "package": "@php scripts/package.php",
        "version:set": "@php scripts/version.php",
        "release:patch": "@php scripts/release.php patch",
        "release:minor": "@php scripts/release.php minor",
        "release:major": "@php scripts/release.php major"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "ext-zip": "*",
        "ablogcms/testing-framework": "3.2.*",
        "phpcompatibility/php-compatibility": "^10.0@dev",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "extra": {
        "acms-plugin-tools": {
            "sourceDir": "app"
        }
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpcsstandards/composer-installer": true
        },
        "platform": {
            "php": "8.5.0"
        }
    }
}
