{
  "name": "acms-ai",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "start": "pnpm run dev",
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.29.1",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.2.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-tooltip": "^5.28.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.20.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
